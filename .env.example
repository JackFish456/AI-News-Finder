# OpenAI (required for LLM scoring, clustering assist, summarization)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database: sqlite (default) or postgresql
DATABASE_URL=sqlite:///./data/news_agent.sqlite3

# Reddit OAuth (optional — without credentials Reddit collector returns stub/empty)
# Register an app at https://www.reddit.com/prefs/apps
REDDIT_ENABLED=false
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-news-brief/0.1 by YourUsername

# X/Twitter API v2 (optional — paid access often required)
TWITTER_ENABLED=false
TWITTER_BEARER_TOKEN=

# Pipeline tuning
NEWS_AGENT_CONFIG=config/default.yaml
LOG_LEVEL=INFO
MOCK_EXTERNAL_APIS=false

# Time window for "last 24 hours" (override for tests)
# PIPELINE_SINCE_HOURS=24
